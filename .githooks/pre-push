#!/bin/sh
#
# Pre-push hook: ensures user-facing file changes include a version bump
# in both index.html and sw.js.

USER_FACING="app.js style.css index.html sw.js manifest.json icon.svg"
remote="$1"

while read local_ref local_oid remote_ref remote_oid; do
  if [ "$remote_oid" = "0000000000000000000000000000000000000000" ]; then
    range="$local_oid"
  else
    range="$remote_oid..$local_oid"
  fi

  changed=$(git diff --name-only "$range" 2>/dev/null)
  if [ -z "$changed" ]; then
    continue
  fi

  needs_bump=false
  for f in $USER_FACING; do
    if echo "$changed" | grep -qx "$f"; then
      needs_bump=true
      break
    fi
  done

  if [ "$needs_bump" = false ]; then
    continue
  fi

  html_bumped=false
  sw_bumped=false

  if echo "$changed" | grep -qx "index.html"; then
    if git diff "$range" -- index.html | grep -qE '^\+.*id="version"'; then
      html_bumped=true
    fi
  fi

  if echo "$changed" | grep -qx "sw.js"; then
    if git diff "$range" -- sw.js | grep -qE '^\+.*CACHE_NAME'; then
      sw_bumped=true
    fi
  fi

  if [ "$html_bumped" = false ] || [ "$sw_bumped" = false ]; then
    echo "ERROR: User-facing files changed but version not bumped in both places."
    echo ""
    echo "  You must update:"
    if [ "$html_bumped" = false ]; then
      echo "    - index.html: <div id=\"version\">vN</div>"
    fi
    if [ "$sw_bumped" = false ]; then
      echo "    - sw.js: CACHE_NAME = \"solitaire-vN\""
    fi
    echo ""
    echo "  Both must use the same version number."
    exit 1
  fi
done

exit 0
